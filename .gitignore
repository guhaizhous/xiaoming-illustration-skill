# 忽略的文件和目录

# 日志文件
*.log
*.log.*

# 临时文件
*.tmp
*.temp

# 缓存目录
.cache/
__pycache__/
*.pyc
*.pyo

# 编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~

# OS 文件
.DS_Store
Thumbs.db

# 生成的图片（示例图片除外）
assets/
*.png
*.jpg
*.jpeg

# 环境变量
.env
.env.local
.env.*.local

# Node.js
node_modules/
package-lock.json
yarn.lock

# Python
venv/
.env/
